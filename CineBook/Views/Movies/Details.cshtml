@model CineBook.Dtos.Movies.MovieDetailsDto

@{
    ViewData["Title"] = Model.Title;
}

<div class="mb-3">
    <a asp-controller="Movies"
       asp-action="Index"
       class="text-decoration-none">
        &larr; Back to Movies
    </a>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4 col-lg-3">
        <img src="@Model.PosterUrl"
             class="img-fluid rounded shadow-sm movie-details-poster"
             alt="@Model.Title poster">
    </div>

    <div class="col-md-8 col-lg-9">
        <h1 class="h2">@Model.Title</h1>

        <p class="text-muted mb-3">
            @Model.Genre | @Model.DurationMinutes min | @Model.Language
        </p>

        <p>@Model.Description</p>

        <dl class="row">
            <dt class="col-sm-3">Release Date</dt>
            <dd class="col-sm-9">
                @Model.ReleaseDate.ToString("dd MMM yyyy")
            </dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.Status</dd>
        </dl>
    </div>
</div>

<section>
    <h2 class="h4 mb-3">Showtimes</h2>

    @if (Model.Showtimes.Any())
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Hall</th>
                        <th>Normal</th>
                        <th>VIP</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var showtime in Model.Showtimes)
                    {
                        <tr>
                            <td>
                                @showtime.StartTime.ToString("dd MMM yyyy")
                            </td>

                            <td>
                                @showtime.StartTime.ToString("hh:mm tt")
                            </td>

                            <td>@showtime.HallName</td>

                            <td>
                                @showtime.NormalPrice.ToString("0.00") EGP
                            </td>

                            <td>
                                @showtime.VipPrice.ToString("0.00") EGP
                            </td>

                            <td class="text-end">
                                <a asp-controller="Showtimes"
                                   asp-action="Select"
                                   asp-route-id="@showtime.Id"
                                   class="btn btn-dark btn-sm">
                                    Book
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <p class="text-muted">
            No showtimes are available for this movie yet.
        </p>
    }
</section>
