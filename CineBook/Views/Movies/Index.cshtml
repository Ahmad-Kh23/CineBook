@model CineBook.ViewModels.MovieIndexViewModel

@{
    ViewData["Title"] = "Movies";
}

<div class="mb-4">
    <h1 class="h3">Movies</h1>
    <p class="text-muted mb-0">Browse current movies and upcoming releases.</p>
</div>

<section class="mb-5">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h4 mb-0">Now Showing</h2>
    </div>

    @if (Model.NowShowingMovies.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
            @foreach (var movie in Model.NowShowingMovies)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="@movie.PosterUrl" class="card-img-top movie-poster" alt="@movie.Title poster">
                        <div class="card-body d-flex flex-column">
                            <h3 class="h6 card-title">@movie.Title</h3>
                            <p class="card-text text-muted small mb-3">@movie.Genre | @movie.DurationMinutes min</p>
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="btn btn-dark btn-sm mt-auto">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No movies are showing right now.</p>
    }
</section>

<section>
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="h4 mb-0">Coming Soon</h2>
    </div>

    @if (Model.ComingSoonMovies.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
            @foreach (var movie in Model.ComingSoonMovies)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <img src="@movie.PosterUrl" class="card-img-top movie-poster" alt="@movie.Title poster">
                        <div class="card-body d-flex flex-column">
                            <h3 class="h6 card-title">@movie.Title</h3>
                            <p class="card-text text-muted small mb-3">@movie.Genre | @movie.DurationMinutes min</p>
                            <a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.Id" class="btn btn-outline-dark btn-sm mt-auto">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No upcoming movies have been added yet.</p>
    }
</section>
